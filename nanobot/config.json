{
  "providers": {
    "openai": {
      "apiKey": "${NANOBOT_LLM_API_KEY}",
      "apiBase": "${NANOBOT_LLM_BASE_URL}"
    }
  },
  "agents": {
    "defaults": {
      "model": "coder-model",
      "provider": "openai",
      "workspace": "./workspace"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": false,
    "webchat": {
      "enabled": true,
      "address": "0.0.0.0",
      "port": "${NANOBOT_WEBCHAT_CONTAINER_PORT}",
      "allow_from": ["*"],
      "access_key": "${NANOBOT_ACCESS_KEY}"
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms.server"],
        "cwd": "/app/nanobot/mcp",
        "env": {
          "GATEWAY_BASE_URL": "${GATEWAY_BASE_URL}",
          "LMS_API_KEY": "${LMS_API_KEY}"
        }
      },
      "observability": {
        "command": "python",
        "args": ["/app/nanobot/mcp/mcp_observability/server.py"],
        "cwd": "/app/nanobot/mcp",
        "env": {
          "VICTORIALOGS_URL": "http://victorialogs:9428",
          "VICTORIATRACES_URL": "http://victoriatraces:8428"
        }
      }
    }
  }
}
