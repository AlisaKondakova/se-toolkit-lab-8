{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "openai",
      "maxTokens": 500,
      "temperature": 0.1,
      "skills": true
    }
  },
  "providers": {
    "openai": {
      "apiKey": "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",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "tools": {
    "mcpServers": {
      "lms": {
        "command": "python",
        "args": ["-m", "mcp_lms"],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "one-two"
        }
      }
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  }
}
