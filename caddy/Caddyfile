:80 {
    handle /ws/chat {
        reverse_proxy http://nanobot:8081 {
            header_up Upgrade {http.request.header.Upgrade}
            header_up Connection {http.request.header.Connection}
        }
    }

    handle_path /flutter/* {
        reverse_proxy http://client-web-flutter:80 {
            header_up Host {http.request.header.Host}
        }
    }

    handle_path /utils/victorialogs/* {
        reverse_proxy http://victorialogs:9428
    }

    handle_path /utils/victoriatraces/* {
        reverse_proxy http://victoriatraces:8428
    }

    handle /items* {
        reverse_proxy http://backend:42002
    }

    handle /health* {
        reverse_proxy http://backend:42002
    }

    handle /interactions* {
        reverse_proxy http://backend:42002
    }

    handle /learners* {
        reverse_proxy http://backend:42002
    }

    handle /pipeline* {
        reverse_proxy http://backend:42002
    }

    handle /analytics* {
        reverse_proxy http://backend:42002
    }

    handle /docs {
        reverse_proxy http://backend:42002
    }

    handle /openapi.json {
        reverse_proxy http://backend:42002
    }
}
